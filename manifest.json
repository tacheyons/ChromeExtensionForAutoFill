{
  "manifest_version": 3,
  "name": "Workday Job Autofill",
  "version": "1.0.0",
  "description": "Automatically fills Workday job application forms using your saved profile.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*.myworkdayjobs.com/*",
    "*://*.wd1.myworkdayjobs.com/*",
    "*://*.wd3.myworkdayjobs.com/*",
    "*://*.wd5.myworkdayjobs.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Workday Autofill"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.myworkdayjobs.com/*",
        "*://*.wd1.myworkdayjobs.com/*",
        "*://*.wd3.myworkdayjobs.com/*",
        "*://*.wd5.myworkdayjobs.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
